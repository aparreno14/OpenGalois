{
  "$defs": {
    "object_ref": {
      "additionalProperties": false,
      "properties": {
        "ref": {
          "description": "Reference to '$input' or a key in the top-level 'objects' map.",
          "minLength": 1,
          "pattern": "^(?:\\$input|[A-Za-z0-9_.:-]+)$",
          "type": "string"
        }
      },
      "required": [
        "ref"
      ],
      "type": "object"
    },
    "proof_node": {
      "additionalProperties": false,
      "properties": {
        "children": {
          "items": {
            "$ref": "#/$defs/proof_node"
          },
          "type": "array"
        },
        "data": {
          "additionalProperties": true,
          "description": "Optional step-local computed data for pedagogy/audit; non-normative.",
          "type": "object"
        },
        "inputs": {
          "items": {
            "$ref": "#/$defs/object_ref"
          },
          "type": "array"
        },
        "kind": {
          "description": "Lemma/step identifier (stable).",
          "minLength": 1,
          "type": "string"
        },
        "outputs": {
          "items": {
            "$ref": "#/$defs/object_ref"
          },
          "type": "array"
        },
        "statement": {
          "description": "Human-readable mathematical statement for this step.",
          "type": "string"
        },
        "witness": {
          "additionalProperties": true,
          "description": "Step-local witness payload (verifier-defined).",
          "type": "object"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "rational_canonical": {
      "description": "Canonical Q element: 0 | nonzero integer | reduced fraction p/q with q>=2, gcd(|p|,q)=1, q>0. Disallows '-0' and any denominator 1.",
      "pattern": "^(?:0|-?[1-9][0-9]*|-?[1-9][0-9]*/(?:[2-9][0-9]*|1[0-9]+))$",
      "type": "string"
    },
    "rational_nonzero_canonical": {
      "description": "Canonical nonzero Q element: nonzero integer | reduced fraction p/q with q>=2, gcd(|p|,q)=1, q>0. Disallows '-0' and any denominator 1.",
      "pattern": "^(?:-?[1-9][0-9]*|-?[1-9][0-9]*/(?:[2-9][0-9]*|1[0-9]+))$",
      "type": "string"
    },
    "sha256_hex": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "https://opengalois.org/schemas/certificate/2.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "input": {
            "properties": {
              "degree": {
                "const": 1
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "input": {
            "properties": {
              "coeffs_qq": {
                "maxItems": 2,
                "minItems": 2
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "input": {
            "properties": {
              "degree": {
                "const": 2
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "input": {
            "properties": {
              "coeffs_qq": {
                "maxItems": 3,
                "minItems": 3
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "input": {
            "properties": {
              "degree": {
                "const": 3
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "input": {
            "properties": {
              "coeffs_qq": {
                "maxItems": 4,
                "minItems": 4
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "input": {
            "properties": {
              "degree": {
                "const": 4
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "input": {
            "properties": {
              "coeffs_qq": {
                "maxItems": 5,
                "minItems": 5
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "input": {
            "properties": {
              "degree": {
                "const": 5
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "input": {
            "properties": {
              "coeffs_qq": {
                "maxItems": 6,
                "minItems": 6
              }
            }
          }
        }
      }
    },
    {
      "properties": {
        "input": {
          "properties": {
            "coeffs_qq": {
              "items": {
                "$ref": "#/$defs/rational_canonical"
              },
              "prefixItems": [
                {
                  "$ref": "#/$defs/rational_nonzero_canonical"
                }
              ]
            }
          }
        }
      }
    }
  ],
  "description": "Proof-carrying, glass-box certificate for polynomials over Q of degree 1..5. Proof obligations are expressed as a derivation tree over typed objects.",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "description": "Namespaced extension point.",
      "type": "object"
    },
    "input": {
      "additionalProperties": false,
      "properties": {
        "canonicalization": {
          "const": "jcs-rfc8785"
        },
        "coeffs_qq": {
          "description": "Coefficients [a_n,...,a_0] in canonical Q encoding (descending degree).",
          "items": {
            "$ref": "#/$defs/rational_canonical"
          },
          "maxItems": 6,
          "minItems": 2,
          "type": "array"
        },
        "degree": {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        "domain": {
          "const": "Q"
        },
        "hash": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "hash_alg": {
          "const": "sha256"
        },
        "hash_scope": {
          "const": "input_v1",
          "description": "Hash computed over JCS({domain,variable,ordering,degree,coeffs_qq})."
        },
        "ordering": {
          "const": "descending_degree"
        },
        "variable": {
          "const": "x"
        }
      },
      "required": [
        "domain",
        "variable",
        "ordering",
        "degree",
        "coeffs_qq",
        "canonicalization",
        "hash_alg",
        "hash_scope",
        "hash"
      ],
      "type": "object"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "backend": {
          "minLength": 1,
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "generator": {
          "minLength": 1,
          "type": "string"
        },
        "generator_version": {
          "type": "string"
        },
        "options": {
          "additionalProperties": true,
          "type": "object"
        },
        "schema_version": {
          "const": "2.0.0"
        }
      },
      "required": [
        "schema_version",
        "generator",
        "backend"
      ],
      "type": "object"
    },
    "objects": {
      "additionalProperties": {
        "additionalProperties": true,
        "properties": {
          "kind": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "kind"
        ],
        "type": "object"
      },
      "description": "Optional object store for sharing computed mathematical objects across proof steps. Keys are stable IDs.",
      "type": "object"
    },
    "proof": {
      "additionalProperties": false,
      "properties": {
        "root": {
          "$ref": "#/$defs/proof_node"
        },
        "version": {
          "default": "0.1",
          "description": "Proof tree format version.",
          "type": "string"
        }
      },
      "required": [
        "version",
        "root"
      ],
      "type": "object"
    },
    "summary": {
      "additionalProperties": false,
      "description": "Optional non-normative summary for UX. Verifiers MUST rely on proof + recomputation, not on this section.",
      "properties": {
        "galois_group": {
          "type": [
            "string",
            "null"
          ]
        },
        "solvable_by_radicals": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "status": {
          "enum": [
            "ok",
            "reducible",
            "unclassified",
            "error"
          ],
          "type": "string"
        },
        "transitive_group_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    }
  },
  "required": [
    "meta",
    "input",
    "proof"
  ],
  "title": "OpenGalois Proof-Carrying Certificate",
  "type": "object"
}